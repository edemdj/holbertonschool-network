#!/usr/bin/env bash
# Checks if an argument is passed on the command line
if [ $# -eq 0 ]; then
    echo "Utilisation : $0 {IP_ADDRESS}"
    exit 1
fi
# Checks if IP address is valid
if [[ ! $1 =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Adresse IP invalide."
    exit 1
fi
# IP address to ping
ip_address="$1"

# Number of times to ping IP address
ping_count=5

# Ping IP address
echo "Ping de l'adresse IP : $ip_address"
ping -c $ping_count $ip_address
